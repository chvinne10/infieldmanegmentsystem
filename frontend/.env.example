# Frontend Environment Variables
# Copy this file to frontend/.env and update values

# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_SOCKET_URL=http://localhost:8000
# For deployed backend, uncomment and use the deployed Render backend URL:
# VITE_API_URL=https://gd-ai-h8zg.onrender.com/api
# VITE_SOCKET_URL=https://gd-ai-h8zg.onrender.com

# App Configuration
VITE_APP_NAME=Smart Field Work Manager
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_VOICE_ASSISTANT=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_WEBSOCKET=true

# Firebase (Optional)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Google Maps (Optional)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Development
VITE_DEBUG=false
VITE_LOG_LEVEL=info
